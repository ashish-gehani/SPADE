#!/bin/bash

# SPADE - Support for Provenance Auditing in Distributed Environments.
# Copyright (C) 2026 SRI International.

# This script manages two kinds of commands:
#
#   Server commands (start, unikernel, debug, java-start) launch a SPADE server
#   process. start, unikernel, and java-start run the server in the background;
#   debug runs it in the foreground.
#
#   Non-server commands (stop, kill, status, control, query, mcp, run-util,
#   java-stop, java-kill) operate on or alongside a running server.


# constants
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
SPADE_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )"/../ && pwd )"

SPADE_SERVER_PID_FILE="${SPADE_ROOT}/spade.pid"

JAVALIBPATH="${SPADE_ROOT}/lib/"
CLASSPATH_SCRIPT="${SPADE_ROOT}/bin/classpath.sh"
CLASSPATH_FILE="${SPADE_ROOT}/build/java-cp.argfile"

JVM_SERVER_MEM_MIN_DEFAULT="8G"
JVM_SERVER_MEM_MAX_DEFAULT="16G"

JVM_NON_SERVER_MEM_MIN_DEFAULT="1G"
JVM_NON_SERVER_MEM_MAX_DEFAULT="2G"

# globals
JVM_MEM_MIN=""
JVM_MEM_MAX=""
JVM_DEBUG_REMOTE_FLAGS=""
JVM_DEBUG_REMOTE_PORT=""
JVM_NON_SERVER_CYGWIN_FLAGS=""
EXTRA_ARGS=()
COMMAND=""


function log() {
    echo "$1"
}

# java command construction

function adjust_for_cygwin() {
    if [[ "$(uname)" == *"CYGWIN"* ]]; then
        SPADE_ROOT="$(cygpath -w "${SPADE_ROOT}")"
        JAVALIBPATH="${SPADE_ROOT}\\lib\\"
        JVM_NON_SERVER_FLAGS="-Djline.terminal=jline.UnixTerminal"
    fi
}

function get_jvm_server_flags() {
    local mem_min="${JVM_MEM_MIN:-${JVM_SERVER_MEM_MIN_DEFAULT}}"
    local mem_max="${JVM_MEM_MAX:-${JVM_SERVER_MEM_MAX_DEFAULT}}"
    echo "-server -Xms${mem_min} -Xmx${mem_max} ${JVM_DEBUG_REMOTE_FLAGS}"
}

function get_jvm_non_server_flags() {
    local mem_min="${JVM_MEM_MIN:-${JVM_NON_SERVER_MEM_MIN_DEFAULT}}"
    local mem_max="${JVM_MEM_MAX:-${JVM_NON_SERVER_MEM_MAX_DEFAULT}}"
    echo "-Xms${mem_min} -Xmx${mem_max} ${JVM_DEBUG_REMOTE_FLAGS} ${JVM_NON_SERVER_FLAGS}"
}

function build_java_server_cmd() {
    echo "java $(get_jvm_server_flags) -Djava.library.path=${JAVALIBPATH} @${CLASSPATH_FILE}"
}

function build_java_non_server_cmd() {
    echo "java $(get_jvm_non_server_flags) -Djava.library.path=${JAVALIBPATH} @${CLASSPATH_FILE}"
}

function build_jvm_debug_remote_flags() {
    if [ -n "${JVM_DEBUG_REMOTE_PORT}" ]; then
        JVM_DEBUG_REMOTE_FLAGS="-Xdebug -Xrunjdwp:server=y,transport=dt_socket,address=${JVM_DEBUG_REMOTE_PORT},suspend=n"
    fi
}

function build_classpath_file() {
    mkdir -p "${SPADE_ROOT}/build"
    if [[ $? -ne 0 ]]; then
        log "Failed to create build directory"
        return 1
    fi
    local classpath
    classpath="$("${CLASSPATH_SCRIPT}")"
    if [[ $? -ne 0 ]]; then
        log "Failed to generate classpath"
        return 1
    fi
    printf -- '-cp\n%s\n' "${classpath}" > "${CLASSPATH_FILE}"
    if [[ $? -ne 0 ]]; then
        log "Failed to write classpath file"
        return 1
    fi
}

function prepare_java_env() {
    adjust_for_cygwin
    build_jvm_debug_remote_flags
    build_classpath_file
    if [[ $? -ne 0 ]]; then
        return 1
    fi
}

# server

function spade_server_pid_file_create() {
    touch "${SPADE_SERVER_PID_FILE}"
}

function spade_server_pid_file_write() {
    echo -n "$1" > "${SPADE_SERVER_PID_FILE}"
}

function spade_server_pid_file_read() {
    cat "${SPADE_SERVER_PID_FILE}"
}

function spade_server_pid_file_delete() {
    rm -f "${SPADE_SERVER_PID_FILE}"
}

function spade_server_stop() {
    local force="${1:-0}"

    if [ ! -f "${SPADE_SERVER_PID_FILE}" ]; then
        log "SPADE server is not running"
        return
    fi

    local pid
    pid=$(spade_server_pid_file_read)

    if [ -z "${pid}" ]; then
        log "PID file exists but is empty"
        spade_server_pid_file_delete
        return
    fi

    if ! ps -p "${pid}" > /dev/null 2>&1; then
        log "SPADE server is not running, but PID file exists"
        spade_server_pid_file_delete
        return
    fi

    local signal
    local success_msg
    local failure_msg
    if [ "${force}" -eq 1 ]; then
        signal=9
        success_msg="Stopping SPADE server immediately (PID ${pid})"
        failure_msg="SPADE server process could not be killed (PID ${pid})"
    else
        signal=15
        success_msg="SPADE server will stop after buffers clear (PID ${pid})"
        failure_msg="SPADE server process could not be stopped (PID ${pid})"
    fi

    kill -"${signal}" "${pid}"
    if [ $? -eq 0 ]; then
        spade_server_pid_file_delete
        log "${success_msg}"
    else
        log "${failure_msg}"
    fi
}

function spade_server_status() {
    if [ ! -f "${SPADE_SERVER_PID_FILE}" ]; then
        log "Stopped"
        return
    fi

    local pid
    pid=$(spade_server_pid_file_read)

    if [ -n "${pid}" ]; then
        if ps -p "${pid}" > /dev/null 2>&1; then
            log "Running (PID ${pid})"
            return
        fi
    fi
    log "Stopped"
}

function spade_server_check_not_running() {
    if [ -f "${SPADE_SERVER_PID_FILE}" ]; then
        local pid
        pid=$(spade_server_pid_file_read)
        if [ -n "${pid}" ]; then
            if ps -p "${pid}" > /dev/null 2>&1; then
                log "SPADE is already running with PID ${pid}"
                return 1
            fi
        fi
    fi
}

function spade_start() {
    local main_class="$1"

    spade_server_check_not_running
    if [[ $? -ne 0 ]]; then
        return
    fi

    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_server_cmd)"
    local error_file
    error_file="$(mktemp)"
    nohup ${java_cmd} "${main_class}" "${EXTRA_ARGS[@]}" > /dev/null 2>"${error_file}" &
    local pid=$!

    if ! ps -p "${pid}" > /dev/null 2>&1; then
        log "Failed to start SPADE"
        if [ -s "${error_file}" ]; then
            log "$(cat "${error_file}")"
        fi
        rm -f "${error_file}"
        return 1
    fi

    # Two-second window to catch early JVM failures (bad classpath, missing
    # class, port conflict). Errors that surface after this point are not
    # detected here and require reviewing process output directly.
    printf "Starting SPADE server..."
    sleep 2

    if ps -p "${pid}" > /dev/null 2>&1; then
        spade_server_pid_file_write "${pid}"
        printf " Running SPADE with PID = %s\n" "${pid}"
    else
        printf "\n"
        log "Failed to start SPADE"
        if [ -s "${error_file}" ]; then
            log "$(cat "${error_file}")"
        fi
    fi
    rm -f "${error_file}"
}

function spade_server_start() {
    spade_start "spade.core.Kernel"
}

function spade_unikernel_start() {
    spade_start "spade.core.Unikernel"
}

function spade_debug_start() {
    log "Warning: 'debug' is deprecated"
    JVM_MEM_MIN="${JVM_MEM_MIN:-${JVM_SERVER_MEM_MIN_DEFAULT}}"
    JVM_MEM_MAX="${JVM_MEM_MAX:-${JVM_SERVER_MEM_MAX_DEFAULT}}"

    spade_server_check_not_running
    if [[ $? -ne 0 ]]; then
        return
    fi

    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_server_cmd)"
    ${java_cmd} spade.core.Kernel "${EXTRA_ARGS[@]}"
}

# client

function spade_query_client_run() {
    local pid
    if [ -f "${SPADE_SERVER_PID_FILE}" ]; then
        pid=$(spade_server_pid_file_read)
    fi

    if [ -z "${pid}" ]; then
        log "SPADE is not running"
        return
    fi
    if ! ps -p "${pid}" > /dev/null 2>&1; then
        log "SPADE is not running"
        return
    fi

    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_non_server_cmd)"
    ${java_cmd} spade.client.CommandLine "$@"
}

function spade_control_client_run() {
    local pid
    if [ -f "${SPADE_SERVER_PID_FILE}" ]; then
        pid=$(spade_server_pid_file_read)
    fi

    if [ -z "${pid}" ]; then
        log "SPADE is not running"
        return
    fi
    if ! ps -p "${pid}" > /dev/null 2>&1; then
        log "SPADE is not running"
        return
    fi

    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_non_server_cmd)"
    ${java_cmd} spade.client.Control
}

function spade_mcp_server_run() {
    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_non_server_cmd)"
    ${java_cmd} spade.utility.mcp.server.Main "${EXTRA_ARGS[@]}"
}

