function spade_run_util() {
    local class_name="spade.utility.${1}"

    prepare_java_env
    if [[ $? -ne 0 ]]; then
        return 1
    fi

    local java_cmd
    java_cmd="$(build_java_non_server_cmd)"
    ${java_cmd} "${class_name}" "${@:2}"
}

function handle_command() {
    case "${COMMAND}" in
        start)
            spade_server_start
            ;;
        unikernel)
            spade_unikernel_start
            ;;
        debug)
            spade_debug_start
            ;;
        # java-start) spade_java_daemonizer_run ;; # legacy
        # java-stop)  spade_java_daemonizer_run ;; # legacy
        # java-kill)  spade_java_daemonizer_run ;; # legacy
        stop)
            spade_server_stop 0
            ;;
        kill)
            spade_server_stop 1
            ;;
        status)
            spade_server_status
            ;;
        control)
            spade_control_client_run
            ;;
        query)
            spade_query_client_run "${EXTRA_ARGS[@]}"
            ;;
        mcp)
            spade_mcp_server_run
            ;;
        run-util)
            spade_run_util "${EXTRA_ARGS[@]}"
            ;;
        help)
            print_help
            ;;
        *)
            print_help
            ;;
    esac
}

function run() {
    pushd "${SPADE_ROOT}" > /dev/null
    handle_command
    popd > /dev/null
}

function print_help() {
    echo "Usage: ${SCRIPT_NAME} <command> [--mem-min <size>] [--mem-max <size>] [--debug-remote-port <port>] [-- <extra-args>]"
    echo ""
    echo "Commands:"
    echo "    start       Starts SPADE"
    echo "    unikernel   Starts SPADE unikernel"
    echo "    debug       Starts SPADE in the foreground without a PID file (deprecated)"
    echo "    stop        Stops SPADE after buffers empty"
    echo "    kill        Stops SPADE immediately"
    echo "    status      Shows SPADE status"
    echo "    control     Starts an interactive SPADE controller"
    echo "    query       Starts an interactive SPADE query client"
    echo "    mcp         Starts the MCP server (usage: ${SCRIPT_NAME} mcp -- <args...>, see docs/mcp/HOW-TO.md)"
    echo "    run-util    Runs a SPADE utility class (usage: ${SCRIPT_NAME} run-util -- <class> [args...])"
    echo "    help        Prints this message"
    # echo "    java-start  Starts SPADE via Daemonizer (legacy)"
    # echo "    java-stop   Stops SPADE via Daemonizer (legacy)"
    # echo "    java-kill   Kills SPADE via Daemonizer (legacy)"
    echo ""
    echo "Options:"
    echo "    --mem-min <size>            Minimum JVM heap size (default: ${JVM_SERVER_MEM_MIN_DEFAULT} for server, ${JVM_NON_SERVER_MEM_MIN_DEFAULT} otherwise)"
    echo "    --mem-max <size>            Maximum JVM heap size (default: ${JVM_SERVER_MEM_MAX_DEFAULT} for server, ${JVM_NON_SERVER_MEM_MAX_DEFAULT} otherwise)"
    echo "    --debug-remote-port <port>  Enable remote JVM debugging on the given port (1-65535, default: disabled)"
    echo "    --                          Pass all following arguments to the invoked command"
    echo "    --help                      Show this message and exit"
    exit 0
}

function parse_args() {
    COMMAND="${1:-}"
    if [[ $# -gt 0 ]]; then
        shift
    fi

    local past_separator=0
    while [[ $# -gt 0 ]]; do
        if [[ "${past_separator}" -eq 1 ]]; then
            EXTRA_ARGS+=("$1")
            shift
            continue
        fi
        case "$1" in
            --help)
                print_help
                ;;
            --)
                past_separator=1
                shift
                ;;
            --mem-min)
                JVM_MEM_MIN="$2"
                shift 2
                ;;
            --mem-max)
                JVM_MEM_MAX="$2"
                shift 2
                ;;
            --debug-remote-port)
                JVM_DEBUG_REMOTE_PORT="$2"
                shift 2
                ;;
            *)
                echo "Unknown argument: $1"
                exit 1
                ;;
        esac
    done
}

function validate_args() {
    if [ -z "${COMMAND}" ]; then
        log "Error: no command specified"
        print_help
        exit 1
    fi

    case "${COMMAND}" in
        start|unikernel|debug|stop|kill|status|control|query|mcp|run-util|help)
            ;;
        *)
            log "Error: unknown command '${COMMAND}'"
            print_help
            exit 1
            ;;
    esac

    if [ -n "${JVM_MEM_MIN}" ]; then
        if ! [[ "${JVM_MEM_MIN}" =~ ^[0-9]+[kKmMgG]$ ]]; then
            log "Error: invalid --mem-min value '${JVM_MEM_MIN}' (expected e.g. 512m, 8g)"
            exit 1
        fi
    fi

    if [ -n "${JVM_MEM_MAX}" ]; then
        if ! [[ "${JVM_MEM_MAX}" =~ ^[0-9]+[kKmMgG]$ ]]; then
            log "Error: invalid --mem-max value '${JVM_MEM_MAX}' (expected e.g. 2g, 16g)"
            exit 1
        fi
    fi

    if [ -n "${JVM_DEBUG_REMOTE_PORT}" ]; then
        if ! [[ "${JVM_DEBUG_REMOTE_PORT}" =~ ^[0-9]+$ ]]; then
            log "Error: invalid --debug-remote-port value '${JVM_DEBUG_REMOTE_PORT}' (expected 1-65535)"
            exit 1
        fi
        if [[ "${JVM_DEBUG_REMOTE_PORT}" -lt 1 || "${JVM_DEBUG_REMOTE_PORT}" -gt 65535 ]]; then
            log "Error: invalid --debug-remote-port value '${JVM_DEBUG_REMOTE_PORT}' (expected 1-65535)"
            exit 1
        fi
    fi
}

function main() {
    parse_args "$@"
    validate_args
    run
}

main "$@"
