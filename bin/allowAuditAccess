# Allow audit access for normal users

###
# CONSTANTS
###

spadeAuditBridgePath="bin/spadeAuditBridge"

###
# RESOLVE PLATFORM
###
os_name=$(uname)
if [ "$os_name" = "Linux" ]
then
  os_release_file="/etc/os-release"
  os_id=$(grep "^ID=" "$os_release_file" | cut -d '=' -f 2)
  os_version=$(grep "^VERSION_ID=" "$os_release_file" | cut -d '=' -f 2)
else
  echo "ERROR: Only Linux supported" && exit 1
fi

###
# RESOLVE PLATFORM REQUIREMENTS
###

# Old Ubuntu location
af_unix_path="/etc/audisp/plugins.d/af_unix.conf"
if sudo test ! -f "${af_unix_path}"; then
    # Location in newer Ubuntu
    af_unix_path="/etc/audit/plugins.d/af_unix.conf"
fi

sudo sed -i "s/active = no/active = yes/" "$af_unix_path"

echo "Setting setuid bits on binaries is not done automatically due to a security"
echo "vulnerability in how Linux distributions handle setuid on copied binaries."
echo "See: https://xint.io/blog/copy-fail-linux-distributions"
echo ""
echo "To grant SPADE the required privileges, please run the following commands manually:"
echo ""
echo "  sudo chmod ug+s \$(which auditctl)"
echo "  sudo chmod ug+s \$(which iptables)"
echo "  sudo chmod ug+s \$(which kmod)"
echo "  sudo chown root \"${spadeAuditBridgePath}\""
echo "  sudo chmod ug+s \"${spadeAuditBridgePath}\""

