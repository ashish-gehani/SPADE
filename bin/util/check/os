source "$(dirname "${BASH_SOURCE[0]}")/check"


function util_check_os_is_darwin() {
    if [[ "$(uname)" == "Darwin" ]]; then
        util_check_checking "os" "$(uname)"
        return 0
    fi
    util_check_checking "os" "$(uname) (only macOS supported)"
    return 1
}
