  <developers>
    <developer>
      <id>irshadh</id>
      <name>Hassaan Irshad</name>
      <url>www.hassaanirshad.com</url>
      <roles>
        <role>Maintainer</role>
      </roles>
      <timezone>America/Los_Angeles</timezone>
