# macfuse
FUSE_MAC_LIB_PATH = $(SPADE_LIB_DIR)/libMacFUSE.jnilib
FUSE_MAC_LIB_JAVA_SRC = $(SPADE_SRC_DIR)/spade/reporter/MacFUSE.java
FUSE_MAC_LIB_C_SRC = $(SPADE_SRC_DIR)/spade/reporter/libMacFUSE.c
FUSE_MAC_NATIVE_HEADER_DIR = $(SPADE_SRC_DIR)/spade/reporter
FUSE_MAC_NATIVE_HEADER_FILE = $(FUSE_MAC_NATIVE_HEADER_DIR)/spade_reporter_MacFUSE.h
FUSE_MAC_JAVA_HOME = $(shell java -classpath $(SPADE_BUILD_DIR) spade.utility.JavaHome)
FUSE_MAC_CFLAGS = $(shell pkg-config fuse --cflags --libs)

.PHONY: macfuse-build macfuse-clean

macfuse-build: ## Compile the MacFUSE shared library
	$(JAVAC) $(JAVAC_OPTIONS) -h $(FUSE_MAC_NATIVE_HEADER_DIR) $(FUSE_MAC_LIB_JAVA_SRC)
	$(CC) -dynamiclib \
		-I$(FUSE_MAC_JAVA_HOME) \
		-I$(FUSE_MAC_JAVA_HOME)/darwin \
		-I$(FUSE_MAC_NATIVE_HEADER_DIR) \
		$(FUSE_MAC_LIB_C_SRC) \
		$(FUSE_MAC_CFLAGS) \
		-o $(FUSE_MAC_LIB_PATH)

macfuse-clean: ## Remove the MacFUSE shared library and JNI header
	@rm -f $(FUSE_MAC_NATIVE_HEADER_FILE)
	@rm -f $(basename $(FUSE_MAC_LIB_PATH)).*
