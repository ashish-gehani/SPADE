# SPADE - Support for Provenance Auditing in Distributed Environments.
# Copyright (C) 2026 SRI International.

# mac llvm
LLVM_MAC_PATH = /var/clang+llvm-3.0-x86_64-apple-darwin11
LLVM_MAC_TARGET =
LLVM_MAC_LLVM_TARGET =
LLVM_MAC_TRACER = $(SPADE_SRC_DIR)/spade/reporter/llvmTracer
LLVM_MAC_BRIDGE = $(SPADE_SRC_DIR)/spade/reporter/llvmBridge
LLVM_MAC_CLOSE = $(SPADE_SRC_DIR)/spade/reporter/llvmClose
LLVM_MAC_TRACER_DYLIB = $(SPADE_LIB_DIR)/llvmTracer.dylib
LLVM_MAC_REPLIB_OSFLAG = -D_LLVMREPORTER_MACOSX
LLVM_MAC_CLANG = $(LLVM_MAC_PATH)/bin/clang
LLVM_MAC_OPT = $(LLVM_MAC_PATH)/bin/opt
LLVM_MAC_LLC = $(LLVM_MAC_PATH)/bin/llc
LLVM_MAC_CXX_FLAGS = $(shell $(LLVM_MAC_PATH)/bin/llvm-config --cxxflags)
LLVM_MAC_C_FLAGS = $(shell $(LLVM_MAC_PATH)/bin/llvm-config --cflags)
LLVM_MAC_CLANG_FLAGS = -cc1 -triple x86_64-apple-macosx10.6.8 -emit-obj -mrelax-all -disable-free $(LLVM_MAC_C_FLAGS)
LLVM_MAC_CLANGXX_FLAGS = $(LLVM_MAC_CXX_FLAGS) -m64 -Wl,-flat_namespace -Wl,-undefined,suppress -dynamiclib -mmacosx-version-min=10.6

.PHONY: macllvm-build macllvm-clean

macllvm-build: ## Compile the Mac LLVM tracer and reporter modules
	$(LLVM_MAC_CLANG) $(LLVM_MAC_CLANG_FLAGS) -g \
		-o $(LLVM_MAC_TRACER).o \
		-x c++ $(LLVM_MAC_TRACER).cpp
	$(LLVM_MAC_CLANG) $(LLVM_MAC_CLANGXX_FLAGS) \
		-o $(LLVM_MAC_TRACER_DYLIB) \
		$(LLVM_MAC_TRACER).o
	$(LLVM_MAC_CLANG) -static $(LLVM_MAC_REPLIB_OSFLAG) \
		$(LLVM_MAC_BRIDGE).c -c \
		-o $(LLVM_MAC_BRIDGE).o
	$(LLVM_MAC_CLANG) -c -emit-llvm \
		$(LLVM_MAC_TARGET).c \
		-o $(LLVM_MAC_LLVM_TARGET).bc
	$(LLVM_MAC_OPT) -load $(LLVM_MAC_TRACER_DYLIB) -provenance \
		$(LLVM_MAC_LLVM_TARGET).bc \
		-o $(LLVM_MAC_LLVM_TARGET).bc
	$(LLVM_MAC_LLC) $(LLVM_MAC_LLVM_TARGET).bc \
		-o $(LLVM_MAC_LLVM_TARGET).s
	$(LLVM_MAC_CLANG) $(LLVM_MAC_CLOSE).c -c \
		-o $(LLVM_MAC_CLOSE).o
	$(LLVM_MAC_CLANG) \
		$(LLVM_MAC_LLVM_TARGET).s $(LLVM_MAC_CLOSE).o \
		-dynamiclib -Wl,-flat_namespace -Wl,-undefined,suppress \
		-o $(LLVM_MAC_LLVM_TARGET).dylib
	$(LLVM_MAC_CLANG) \
		$(LLVM_MAC_BRIDGE).o $(LLVM_MAC_LLVM_TARGET).dylib \
		-o $(LLVM_MAC_LLVM_TARGET)

macllvm-clean: ## Remove the Mac LLVM tracer and reporter modules
	@$(if $(LLVM_MAC_LLVM_TARGET),rm -f $(LLVM_MAC_LLVM_TARGET) $(LLVM_MAC_LLVM_TARGET).*,true)
	@rm -f $(LLVM_MAC_TRACER).o
	@rm -f $(LLVM_MAC_BRIDGE).o
	@rm -f $(LLVM_MAC_CLOSE).o
	@rm -f $(LLVM_MAC_TRACER_DYLIB)
