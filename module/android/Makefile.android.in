# SPADE - Support for Provenance Auditing in Distributed Environments.
# Copyright (C) 2026 SRI International.

# toolchain
DX = @DX@

# android
ANDROID_BUILD_DIR = android-build
ANDROID_LIB_DIR = android-lib
ANDROID_SPADE_JAR = android-spade.jar
ANDROID_DEVICE_SDCARD = /sdcard
ANDROID_DEVICE_SPADE_DIR = $(ANDROID_DEVICE_SDCARD)/spade

.PHONY: android-build android-start android-stop android-clean

android-build: ## Package SPADE classes into an Android DEX jar
	@mkdir -p "$(ANDROID_BUILD_DIR)"; \
	$(DX) --dex --verbose --no-strict \
		--output="$(SPADE_ROOT)/$(ANDROID_BUILD_DIR)/$(ANDROID_SPADE_JAR)" \
		"$(SPADE_BUILD_DIR)/spade"


android-start: ## Deploy and start SPADE on connected Android device
	bin/build/android/start.sh \
		--android_build $(ANDROID_BUILD_DIR) \
		--device_sdcard $(ANDROID_DEVICE_SDCARD) \
		--device_spade_dir $(ANDROID_DEVICE_SPADE_DIR) \
		--spade_jar $(ANDROID_SPADE_JAR)

android-stop: ## Stop SPADE on connected Android device
	bin/build/android/stop.sh \
		--device_sdcard $(ANDROID_DEVICE_SDCARD) \
		--device_spade_dir $(ANDROID_DEVICE_SPADE_DIR) \
		--spade_jar $(ANDROID_SPADE_JAR)

android-clean: ## Remove Android build artifacts
	@rm -rf "$(ANDROID_BUILD_DIR)" "$(ANDROID_LIB_DIR)"
