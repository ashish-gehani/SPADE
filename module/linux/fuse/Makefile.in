# linuxfuse
FUSE_LINUX_LIB_JAVA_SRC = $(SPADE_SRC_DIR)/spade/reporter/LinuxFUSE.java
FUSE_LINUX_LIB_C_SRC = $(SPADE_SRC_DIR)/spade/reporter/libLinuxFUSE.c
FUSE_LINUX_NATIVE_HEADER_DIR = $(SPADE_SRC_DIR)/spade/reporter
FUSE_LINUX_NATIVE_HEADER_FILE = $(FUSE_LINUX_NATIVE_HEADER_DIR)/spade_reporter_LinuxFUSE.h
FUSE_LINUX_LIB_PATH = $(SPADE_LIB_DIR)/libLinuxFUSE.so
FUSE_LINUX_JAVA_HOME = $(shell java -classpath $(SPADE_BUILD_DIR) spade.utility.JavaHome)
FUSE_LINUX_CFLAGS = $(shell PKG_CONFIG_PATH=$(OS_CONFIG_PATH) pkg-config fuse --cflags --libs)

.PHONY: linuxfuse-build linuxfuse-clean

linuxfuse-build: ## Compile the LinuxFUSE shared library
	$(JAVAC) $(JAVAC_OPTIONS) -h $(FUSE_LINUX_NATIVE_HEADER_DIR) $(FUSE_LINUX_LIB_JAVA_SRC)
	$(CC) -fPIC -shared \
		-Wl,-soname,$(notdir $(FUSE_LINUX_LIB_PATH)) \
		-I$(FUSE_LINUX_JAVA_HOME) \
		-I$(FUSE_LINUX_JAVA_HOME)/linux \
		-I$(FUSE_LINUX_NATIVE_HEADER_DIR) \
		-Wall \
		$(FUSE_LINUX_LIB_C_SRC) \
		$(FUSE_LINUX_CFLAGS) \
		-o $(FUSE_LINUX_LIB_PATH)

linuxfuse-clean: ## Remove the LinuxFUSE shared library and JNI header
	@rm -f $(FUSE_LINUX_NATIVE_HEADER_FILE)
	@rm -f $(basename $(FUSE_LINUX_LIB_PATH)).*
