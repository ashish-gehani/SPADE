# linux kernel module
KERNEL_MODULES ?= false
KERNEL_MODULES_DEBUG ?= false
KERNEL_MODULE_SRC = $(SPADE_SRC_DIR)/spade/reporter/audit/kernel-modules
KERNEL_MODULE_INSTALL = $(SPADE_LIB_DIR)/kernel-modules
KERNEL_MODULE_TARGET = $(if $(filter true,$(KERNEL_MODULES_DEBUG)),debug,release)

.PHONY: kernel-module-build kernel-module-clean

kernel-module-build: ## Compile the Linux audit kernel modules
	$(MAKE) --no-print-directory -C $(KERNEL_MODULE_SRC) INSTALL_DIR=$(KERNEL_MODULE_INSTALL) $(KERNEL_MODULE_TARGET) install

kernel-module-clean: ## Remove the Linux audit kernel modules
	$(MAKE) --no-print-directory -C $(KERNEL_MODULE_SRC) INSTALL_DIR=$(KERNEL_MODULE_INSTALL) clean
