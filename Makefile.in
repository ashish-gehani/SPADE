# SPADE - Support for Provenance Auditing in Distributed Environments.
# Copyright (C) 2015 SRI International.

# toolchain
JAVAC=@JAVAC@
CC=@CC@
CLANG=@CLANG@
CLANGXX=@CLANGXX@
JAVAC_CP = $(shell ./bin/classpath.sh)
JAVAC_OPTIONS = $(EXTRA_JAVAC_OPTIONS) -Xlint:none -proc:none -cp '$(JAVAC_CP)'

# build
SPADE_ROOT = $(shell pwd)
SPADE_BUILD_DIR = $(SPADE_ROOT)/build
SPADE_LIB_DIR = $(SPADE_ROOT)/lib
SPADE_SRC_DIR = $(SPADE_ROOT)/src
SPADE_BIN_DIR = $(SPADE_ROOT)/bin
SPADE_JAR = $(SPADE_LIB_DIR)/spade.jar

include Makefile.java
include module/android/Makefile
include module/mac/fuse/Makefile
include module/mac/llvm/Makefile
include module/mac/openbsm/Makefile
include module/linux/audit_bridge/Makefile
include module/linux/fuse/Makefile
include module/linux/kernel_module/Makefile
include module/linux/llvm/Makefile

# runtime
OS_NAME = $(shell uname)

 
# System and architecture-specific configuration
ifeq ($(OS_NAME), Darwin)
	OS_BUILD = build-openbsm
	NO_FUSE = $(shell pkg-config fuse; echo $$?)
	ifeq (0, $(NO_FUSE))
   	 OS_BUILD += build-macfuse
	endif
	OS_CONFIG_PATH = /usr/local/lib/pkgconfig
	LLVM_RULE = build-mac-llvm
endif
ifeq ($(OS_NAME), Linux)
	OS_BUILD = build-linuxaudit
	NO_FUSE = $(shell pkg-config fuse; echo $$?)
	ifeq (0, $(NO_FUSE))
   	 OS_BUILD += build-linuxfuse
	endif
	OS_CONFIG_PATH = /usr/lib/pkgconfig
	LLVM_RULE = build-linux-llvm
endif

.PHONY: build

all: build ## Compile SPADE and generate keys
	./bin/keys/generatekeys.sh

help: ## List available targets
	@grep -E '^[a-zA-Z_-]+:.*?##' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-28s %s\n", $$1, $$2}'

echo-javac-options:
	@echo "$(JAVAC_OPTIONS)"

# ---------- Building SPADE ----------
.SECONDEXPANSION:

build: java-build $$(OS_BUILD) ## Compile Java sources and platform-specific reporters

build-linuxaudit: audit-bridge-build ## Build the LinuxAudit reporter

clean-linuxaudit: kernel-module-clean audit-bridge-clean

ifeq ($(KERNEL_MODULES),true)
build-linuxaudit: kernel-module-build
endif

build-linuxfuse: linuxfuse-build ## Build the LinuxFUSE shared library

clean-linuxfuse: linuxfuse-clean
 
build-openbsm: openbsm-build ## Build the OpenBSM reporter (macOS)

clean-openbsm: openbsm-clean

build-macfuse: macfuse-build ## Build the MacFUSE reporter (macOS)

clean-macfuse: macfuse-clean

llvm: ## Build LLVM reporters (platform-detected)
	@make $(LLVM_RULE)
 
build-mac-llvm: macllvm-build ## Build the Mac LLVM reporter modules

clean-mac-llvm: macllvm-clean

build-linux-llvm: llvm-linux-build ## Build the Linux LLVM reporter modules

clean-linux-llvm: llvm-linux-clean

graph-utility: ## Run the graph utility
	java -cp '$(JAVAC_CP)' spade.utility.GraphUtility
 
# ---------- Removing files ----------
# Remove Java classes and native libraries, executables that we compiled.
clean: java-clean clean-macfuse clean-mac-llvm clean-linuxfuse android-clean clean-linuxaudit clean-linux-llvm clean-openbsm ## Remove compiled output and generated files
	@rm -rf cfg/ssl
	@rm -rf log
	@rm -rf tmp
 
DESTDIR = @prefix@
install:
	test -d $(DESTDIR) || mkdir $(DESTDIR)
	cp -R bin $(DESTDIR)
	cp -R lib $(DESTDIR)
	cp -R cfg $(DESTDIR)
 
 

