# SPADE - Support for Provenance Auditing in Distributed Environments.
# Copyright (C) 2015 SRI International.

# toolchain
JAVAC=@JAVAC@
CC=@CC@
JAR=@JAR@
JAVAC_CP = $(shell ./bin/classpath.sh)
JAVAC_OPTIONS = $(EXTRA_JAVAC_OPTIONS) -Xlint:none -proc:none -cp '$(JAVAC_CP)'

# build
SPADE_ROOT = $(shell pwd)
SPADE_BUILD_DIR = $(SPADE_ROOT)/build
SPADE_LIB_DIR = $(SPADE_ROOT)/lib
SPADE_SRC_DIR = $(SPADE_ROOT)/src
SPADE_BIN_DIR = $(SPADE_ROOT)/bin
SPADE_JAR = $(SPADE_LIB_DIR)/spade.jar

# fuse linux
FUSE_LINUX_LIB_PATH = $(SPADE_LIB_DIR)/libLinuxFUSE.so
FUSE_LINUX_LIB_JAVA_SRC = $(SPADE_SRC_DIR)/spade/reporter/LinuxFUSE.java
FUSE_LINUX_LIB_C_SRC = $(SPADE_SRC_DIR)/spade/reporter/libLinuxFUSE.c
FUSE_LINUX_NATIVE_HEADER_DIR = $(SPADE_SRC_DIR)/spade/reporter
FUSE_LINUX_NATIVE_HEADER_FILE = $(FUSE_LINUX_NATIVE_HEADER_DIR)/spade_reporter_LinuxFUSE.h
FUSE_LINUX_JAVAC_OPTIONS = $(JAVAC_OPTIONS)

# openbsm mac
OPENBSM_MAC_C_SRC = $(SPADE_SRC_DIR)/spade/reporter/spadeOpenBSM.c
OPENBSM_MAC_OUTPUT = $(SPADE_LIB_DIR)/spadeOpenBSM

# fuse mac
FUSE_MAC_LIB_PATH = $(SPADE_LIB_DIR)/libMacFUSE.jnilib
FUSE_MAC_LIB_JAVA_SRC = $(SPADE_SRC_DIR)/spade/reporter/MacFUSE.java
FUSE_MAC_LIB_C_SRC = $(SPADE_SRC_DIR)/spade/reporter/libMacFUSE.c
FUSE_MAC_NATIVE_HEADER_DIR = $(SPADE_SRC_DIR)/spade/reporter
FUSE_MAC_NATIVE_HEADER_FILE = $(FUSE_MAC_NATIVE_HEADER_DIR)/spade_reporter_MacFUSE.h
FUSE_MAC_JAVAC_OPTIONS = $(JAVAC_OPTIONS)

# audit linux bridge
SPADE_AUDIT_BRIDGE = $(SPADE_BIN_DIR)/spadeAuditBridge

# audit kernel modules
KERNEL_MODULES ?= false
KERNEL_MODULES_DEBUG ?= false
KERNEL_MODULES_SRC = $(SPADE_SRC_DIR)/spade/reporter/audit/kernel-modules
KERNEL_MODULES_INSTALL = $(SPADE_LIB_DIR)/kernel-modules

include module/android/Makefile

# llvm
LLVM_TARGET =
LLVM_LLVM_TARGET =
LLVM_TRACER = $(SPADE_SRC_DIR)/spade/reporter/llvmTracer
LLVM_BRIDGE = $(SPADE_SRC_DIR)/spade/reporter/llvmBridge
LLVM_CLOSE = $(SPADE_SRC_DIR)/spade/reporter/llvmClose
LLVM_TRACER_DYLIB = $(SPADE_LIB_DIR)/llvmTracer.dylib

# runtime
OS_NAME = $(shell uname)

 
# System and architecture-specific configuration
ifeq ($(OS_NAME), Darwin)
	OS_BUILD = build-openbsm
	NO_FUSE = $(shell pkg-config fuse; echo $$?)
	ifeq (0, $(NO_FUSE))
   	 OS_BUILD += build-macfuse
	endif
	OS_CONFIG_PATH = /usr/local/lib/pkgconfig
	LLVM_RULE = build-mac-llvm
endif
ifeq ($(OS_NAME), Linux)
	OS_BUILD = build-linuxaudit
	NO_FUSE = $(shell pkg-config fuse; echo $$?)
	ifeq (0, $(NO_FUSE))
   	 OS_BUILD += build-linuxfuse
	endif
	OS_CONFIG_PATH = /usr/lib/pkgconfig
	LLVM_RULE = build-linux-llvm
endif

# -------- Default Build Configuration -----
REPORTERS = Graphviz DSL Network LLVM Facebook Bitcoin StraceLinux JSON CDM CamFlow ProcMon
# -------------------------------------------
 
.PHONY: build prepare-dirs core reporters filters query analyzers clients utilities storages screens

all: build ## Compile SPADE and generate keys
	./bin/keys/generatekeys.sh

help: ## List available targets
	@grep -E '^[a-zA-Z_-]+:.*?##' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-28s %s\n", $$1, $$2}'

echo-javac-options:
	@echo "$(JAVAC_OPTIONS)"
 
# ---------- Building SPADE ----------    
.SECONDEXPANSION:

build: | prepare-dirs ## Compile Java sources and platform-specific reporters
build: build-java $$(OS_BUILD) $(SPADE_JAR)
# No sketches at the moment available
#build-java: download-neo4j core clients utilities storages filters query analyzers sketches transformers reporters
build-java: download-neo4j core clients utilities storages screens filters query analyzers transformers reporters

download-neo4j:
	@bin/manage-neo4j.sh install

.SUFFIXES : .class .java
 
prepare-dirs:
	mkdir -p $(SPADE_BUILD_DIR)
	mkdir -p tmp

$(SPADE_BUILD_DIR)/%.class : $(SPADE_SRC_DIR)/%.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $<

core:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/core/*.java
	@echo "--- Built Core ---"
clients:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/client/*.java
	@echo "--- Built Clients ---"
reporters: $$(foreach f,$$(REPORTERS), $(SPADE_BUILD_DIR)/spade/reporter/$$(f).class )
	@echo "--- Built Reporters ---"
query:
	find $(SPADE_SRC_DIR)/spade/query -name "*.java" > tmp/query.classes
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) @tmp/query.classes
	rm tmp/query.classes
	@echo "--- Built Queries ---"
analyzers:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/analyzer/*.java
	@echo "--- Built Analyzers ---"
storages:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/storage/*.java
	@echo "--- Built Storages ---"
screens:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/screen/*.java
	@echo "--- Built Screens ---"
utilities:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/profile/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/cache/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/screen/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/store/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/store/db/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/store/db/berkeleydb/*.java
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/utility/map/external/store/db/leveldb/*.java
	@echo "--- Built Utilities ---"
filters:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/filter/*.java
	@echo "--- Built Filters ---"
sketches:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/sketch/*.java
	@echo "--- Built Sketches ---"
transformers:
	$(JAVAC) $(JAVAC_OPTIONS) -sourcepath $(SPADE_SRC_DIR) -d $(SPADE_BUILD_DIR) $(SPADE_SRC_DIR)/spade/transformer/*.java
	@echo "--- Built Transformers ---"

$(SPADE_JAR): build-java $$(OS_BUILD)
	$(JAR) cvf $(SPADE_JAR) -C $(SPADE_BUILD_DIR) .

build-linuxaudit: ## Build the LinuxAudit reporter
	bin/linux/audit/build.sh \
		--audit_bridge $(SPADE_AUDIT_BRIDGE) \
		--spade_src $(SPADE_SRC_DIR)

clean-linuxaudit: clean-linuxaudit-kernel
	@bin/linux/audit/clean.sh \
		--audit_bridge $(SPADE_AUDIT_BRIDGE)

build-linuxaudit-kernel: ## Build Linux audit kernel modules
	bin/linux/audit/kernel/build.sh \
		--kernel_modules_src $(KERNEL_MODULES_SRC) \
		--kernel_modules_install $(KERNEL_MODULES_INSTALL) \
		--kernel_modules_debug $(KERNEL_MODULES_DEBUG)

clean-linuxaudit-kernel:
	@bin/linux/audit/kernel/clean.sh \
		--kernel_modules_src $(KERNEL_MODULES_SRC) \
		--kernel_modules_install $(KERNEL_MODULES_INSTALL)

ifeq ($(KERNEL_MODULES),true)
build-linuxaudit: build-linuxaudit-kernel
endif

build-linuxfuse: ## Build the LinuxFUSE reporter (currently not functional)
	@echo 'WARNING: The LinuxFUSE reporter is not in working condition. Please file an issue at https://github.com/ashish-gehani/SPADE/issues'
	#bin/linux/fuse/build.sh \
	#	--javac $(JAVAC) \
	#	--javac-options "$(FUSE_LINUX_JAVAC_OPTIONS)" \
	#	--spade-build $(SPADE_BUILD_DIR) \
	#	--lib-java-src $(FUSE_LINUX_LIB_JAVA_SRC) \
	#	--lib-c-src $(FUSE_LINUX_LIB_C_SRC) \
	#	--native-header-dir $(FUSE_LINUX_NATIVE_HEADER_DIR) \
	#	--lib-path $(FUSE_LINUX_LIB_PATH)

clean-linuxfuse:
	@bin/linux/fuse/clean.sh \
		--native-header-file $(FUSE_LINUX_NATIVE_HEADER_FILE) \
		--lib-path $(FUSE_LINUX_LIB_PATH)
 
build-openbsm: ## Build the OpenBSM reporter (macOS)
	bin/mac/openbsm/build.sh \
		--c-src $(OPENBSM_MAC_C_SRC) \
		--output $(OPENBSM_MAC_OUTPUT)

clean-openbsm:
	@bin/mac/openbsm/clean.sh \
		--output $(OPENBSM_MAC_OUTPUT)

build-macfuse: ## Build the MacFUSE reporter (macOS)
	bin/mac/fuse/build.sh \
		--javac $(JAVAC) \
		--javac-options "$(FUSE_MAC_JAVAC_OPTIONS)" \
		--spade-build $(SPADE_BUILD_DIR) \
		--lib-java-src $(FUSE_MAC_LIB_JAVA_SRC) \
		--lib-c-src $(FUSE_MAC_LIB_C_SRC) \
		--native-header-dir $(FUSE_MAC_NATIVE_HEADER_DIR) \
		--lib-path $(FUSE_MAC_LIB_PATH)

clean-macfuse:
	@bin/mac/fuse/clean.sh \
		--native-header-file $(FUSE_MAC_NATIVE_HEADER_FILE) \
		--lib-path $(FUSE_MAC_LIB_PATH)

llvm: ## Build LLVM reporters (platform-detected)
	@make $(LLVM_RULE)
 
build-mac-llvm:
	bin/mac/llvm/build.sh \
		--target $(LLVM_TARGET) \
		--llvm-target $(LLVM_LLVM_TARGET) \
		--spade-src $(SPADE_SRC_DIR) \
		--spade-lib $(SPADE_LIB_DIR) \
		--llvm-tracer $(LLVM_TRACER) \
		--llvm-bridge $(LLVM_BRIDGE) \
		--llvm-close $(LLVM_CLOSE) \
		--llvm-tracer-dylib $(LLVM_TRACER_DYLIB)
 
build-linux-llvm:
	bin/linux/llvm/build.sh

graph-utility: ## Run the graph utility
	java -cp '$(JAVAC_CP)' spade.utility.GraphUtility
 
# ---------- Removing files ----------
# Remove Java classes and native libraries, executables that we compiled.
clean: clean-macfuse clean-linuxfuse android-clean clean-linuxaudit clean-openbsm ## Remove compiled output and generated files
	@echo 'Removing Java classes, native libraries, executables...'
	@rm -rf $(SPADE_BUILD_DIR)
	@rm -rf $(SPADE_JAR)
	@rm -rf cfg/ssl
	@rm -rf log
	@rm -rf tmp
 
DESTDIR = @prefix@
install:
	test -d $(DESTDIR) || mkdir $(DESTDIR)
	cp -R bin $(DESTDIR)
	cp -R lib $(DESTDIR)
	cp -R cfg $(DESTDIR)
 
 

